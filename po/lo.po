msgstr "ໃຫ້ຄະແນນຂ້ອຍ"

#: ../src/cairo-dock-widget-themes.c:384 ../src/cairo-dock-widget-themes.c:386
msgid "You must try the theme before you can rate it."
msgstr "ທ່ານຕ້ອງລອງໃຊ້ທີມກ່ອນຈຶ່ງຈະສາມາດໃຫ້ຄະແນນໄດ້."

#: ../src/cairo-dock-widget-themes.c:433
