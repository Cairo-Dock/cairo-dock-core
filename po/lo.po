#: ../data/messages:545
msgid "Ratio for the size of the sub-docks' icons :"
msgstr "ອັດຕາສ່ວນຂະໜາດຂອງໄອຄອນໃນແທ່ນດັອກຍ່ອຍ :"

#: ../data/messages:547 ../data/messages:783
msgid "smaller"
msgstr "ນ້ອຍລົງ"

#: ../data/messages:549
msgid "larger"
msgstr "ໃຫຍ່ຂຶ້ນ"

#: ../data/messages:551
msgid "Dialogs"
msgstr "ກ່ອງໂຕ້ຕອບ"

#: ../data/messages:553
msgid "Bubble"
msgstr "ຟອງ"

#: ../data/messages:561 ../data/messages:849 ../data/messages:875
#: ../data/messages:887
msgid "Background colour"
msgstr "ສີພື້ນຫຼັງ"

#: ../data/messages:565 ../data/messages:853 ../data/messages:873
msgid "Text colour"
msgstr "ສີຕົວອັກສອນ"

#: ../data/messages:571
