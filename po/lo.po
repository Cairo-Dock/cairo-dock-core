msgid "Desired icon size for this applet"
msgstr "ຂະໜາດໄອຄອນທີ່ຕ້ອງການສຳລັບແອັບເປັດນີ້"

#: ../Help/data/messages:279
msgid "Desklet"
msgstr "ເດສເລັດ"

#: ../Help/data/messages:283
msgid ""
"If locked, the desklet cannot be moved by simply dragging it with the left "
"mouse button. It can still be moved with ALT + left-click."
msgstr ""
"ຖ້າຖືກລັອກ, ເດສເລັດຈະບໍ່ສາມາດຍ້າຍໄດ້ໂດຍການລາກດ້ວຍປຸ່ມເມົ້າຊ້າຍ. ມັນຍັງສາມາດຍ້າຍໄດ້ດ້ວຍ ALT + "
"ຄລິກຊ້າຍ."

#: ../Help/data/messages:285
msgid "Lock position?"
msgstr "ລັອກຕຳແໜ່ງບໍ່?"

#: ../Help/data/messages:287
msgid ""
"Depending on your WindowManager, you may be able to resize this with ALT + "
"middle-click or ALT + left-click."
msgstr ""
"ຂຶ້ນກັບໂຕຈັດການໜ້າຕ່າງຂອງທ່ານ, ທ່ານອາດຈະສາມາດປັບຂະໜາດນີ້ໄດ້ດ້ວຍ ALT + ຄລິກກາງ ຫຼື ALT + "
"ຄລິກຊ້າຍ."

#: ../Help/data/messages:289
msgid "Desklet dimensions (width x height):"
