#: ../src/cairo-dock.c:382
msgid "Use Cairo backend."
msgstr "ໃຊ້ Cairo backend."

#: ../src/cairo-dock.c:385
msgid "Use OpenGL backend."
msgstr "ໃຊ້ OpenGL backend."

#: ../src/cairo-dock.c:388
msgid ""
"Use OpenGL backend with indirect rendering. There are very few case where "
"this option should be used."
msgstr "ໃຊ້ OpenGL backend ດ້ວຍການສະແດງຜົນແບບທາງອ້ອມ. ມີກໍລະນີນ້ອຍຫຼາຍທີ່ຄວນໃຊ້ຕົວເລືອກນີ້."

#: ../src/cairo-dock.c:391
msgid "Ask again on startup which backend to use."
msgstr "ຖາມອີກຄັ້ງໃນຕອນເລີ່ມຕົ້ນວ່າຈະໃຊ້ backend ໃດ."

#: ../src/cairo-dock.c:394
msgid "Force the dock to consider this environment - use it with care."
msgstr "ບັງຄັບໃຫ້ດັອກພິຈາລະນາສະພາບແວດລ້ອມນີ້ - ໃຊ້ມັນດ້ວຍຄວາມລະມັດລະວັງ."

#: ../src/cairo-dock.c:397
msgid ""
"Force the dock to load from this directory, instead of ~/.config/cairo-dock."
msgstr "ບັງຄັບໃຫ້ດັອກໂຫຼດຈາກໄດເຣັກທໍຣີນີ້, ແທນທີ່ຈະເປັນ ~/.config/cairo-dock."

#: ../src/cairo-dock.c:400
msgid ""
"Address of a server containing additional themes. This will overwrite the "
"default server address."
msgstr "ທີ່ຢູ່ຂອງເຊີບເວີທີ່ມີທີມເພີ່ມເຕີມ. ອັນນີ້ຈະຂຽນທັບທີ່ຢູ່ເຊີບເວີເລີ່ມຕົ້ນ."

#: ../src/cairo-dock.c:403
msgid ""
"Wait for N seconds before starting; this is useful if you notice some "
"problems when the dock starts with the session."
msgstr ""
"ລໍຖ້າ N ວິນາທີກ່ອນທີ່ຈະເລີ່ມຕົ້ນ; ອັນນີ້ມີປະໂຫຍດຖ້າທ່ານສັງເກດເຫັນບາງບັນຫາເມື່ອດັອກເລີ່ມຕົ້ນກັບເຊດຊັນ."

#: ../src/cairo-dock.c:406
msgid ""
"Allow to edit the config before the dock is started and show the config "
"panel on start."
msgstr "ອະນຸຍາດໃຫ້ແກ້ໄຂການຕັ້ງຄ່າກ່ອນທີ່ດັອກຈະເລີ່ມຕົ້ນ ແລະ ສະແດງແຜງການຕັ້ງຄ່າເມື່ອເລີ່ມຕົ້ນ."

#: ../src/cairo-dock.c:409
msgid "Exclude a given plug-in from activating (it is still loaded though)."
msgstr "ຍົກເວັ້ນປລັກອິນທີ່ໃຫ້ມາຈາກການເປີດໃຊ້ງານ (ແຕ່ມັນຍັງຖືກໂຫຼດຢູ່)."

#: ../src/cairo-dock.c:412
msgid "Don't load any plug-ins."
msgstr "ບໍ່ໂຫຼດປລັກອິນໃດໆ."

#: ../src/cairo-dock.c:415
msgid "Work around potential glitches when dialogs or sub-docks appear"
msgstr "ແກ້ໄຂບັນຫາທີ່ອາດເກີດຂຶ້ນເມື່ອກ່ອງໂຕ້ຕອບ ຫຼື ດັອກຍ່ອຍປາກົດຂຶ້ນ"

#: ../src/cairo-dock.c:418
msgid ""
"Log verbosity (debug,message,warning,critical,error); default is warning."
msgstr ""
"ຄວາມລະອຽດຂອງບັນທຶກ (debug,message,warning,critical,error); ຄ່າເລີ່ມຕົ້ນແມ່ນ warning."

#: ../src/cairo-dock.c:421
msgid "Force to display some output messages with colors."
msgstr "ບັງຄັບໃຫ້ສະແດງຂໍ້ຄວາມບາງຢ່າງດ້ວຍສີ."

#: ../src/cairo-dock.c:424
msgid "Print version and quit."
msgstr "ພິມເວີຊັນ ແລະ ອອກ."

#: ../src/cairo-dock.c:427
msgid "Lock the dock so that any modification is impossible for users."
msgstr "ລັອກດັອກເພື່ອບໍ່ໃຫ້ຜູ້ໃຊ້ສາມາດແກ້ໄຂໃດໆໄດ້."

#: ../src/cairo-dock.c:431
msgid "Keep the dock above other windows."
msgstr "ຮັກສາໃຫ້ດັອກຢູ່ເທິງໜ້າຕ່າງອື່ນໆ."

#: ../src/cairo-dock.c:434
msgid "Don't make the dock appear on all desktops."
msgstr "ບໍ່ໃຫ້ດັອກປາກົດໃນທຸກເດັສທັອບ."

#: ../src/cairo-dock.c:437 ../src/cairo-dock.c:497
msgid "Cairo-Dock makes anything, including coffee !"
msgstr "Cairo-Dock ເຮັດໄດ້ທຸກຢ່າງ, ແມ່ນແຕ່ກາເຟ!"

#: ../src/cairo-dock.c:440
msgid ""
"Ask the dock to load additional modules contained in this directory (though "
"it is unsafe for your dock to load unofficial modules)."
msgstr ""
"ຂໍໃຫ້ດັອກໂຫຼດໂມດູນເພີ່ມເຕີມທີ່ບັນຈຸຢູ່ໃນໄດເຣັກທໍຣີນີ້ "
"(ເຖິງແມ່ນວ່າມັນຈະບໍ່ປອດໄພສຳລັບດັອກຂອງທ່ານທີ່ຈະໂຫຼດໂມດູນທີ່ບໍ່ເປັນທາງການ)."

#: ../src/cairo-dock.c:443
msgid ""
"For debugging purpose only. The crash manager will not be started to hunt "
"down the bugs."
msgstr "ເພື່ອຈຸດປະສົງໃນການດີບັກເທົ່ານັ້ນ. ຕົວຈັດການການຂັດຂ້ອງຈະບໍ່ຖືກເລີ່ມຕົ້ນເພື່ອຊອກຫາຂໍ້ບົກພ່ອງ."

#: ../src/cairo-dock.c:446
msgid ""
"For debugging purpose only. Some hidden and still unstable options will be "
"activated."
msgstr "ເພື່ອຈຸດປະສົງໃນການດີບັກເທົ່ານັ້ນ. ຕົວເລືອກທີ່ເຊື່ອງໄວ້ ແລະ ຍັງບໍ່ສະຖຽນບາງອັນຈະຖືກເປີດໃຊ້ງານ."

#: ../src/cairo-dock.c:449
msgid "Force using the Wayland backends (disable X11 backends)."
msgstr "ບັງຄັບໃຊ້ Wayland backends (ປິດໃຊ້ງານ X11 backends)."

#: ../src/cairo-dock.c:452
msgid "Force using the X11 backend (disable any Wayland functionality)."
msgstr "ບັງຄັບໃຊ້ X11 backend (ປິດການເຮັດວຽກຂອງ Wayland ທັງໝົດ)."

#: ../src/cairo-dock.c:455
msgid "Use EGL on X11."
msgstr "ໃຊ້ EGL ໃນ X11."

#: ../src/cairo-dock.c:458
msgid "For debugging purpose only. Disable gtk-layer-shell support."
msgstr "ເພື່ອຈຸດປະສົງໃນການດີບັກເທົ່ານັ້ນ. ປິດການຮອງຮັບ gtk-layer-shell."

#: ../src/cairo-dock.c:461
msgid ""
"For debugging purpose only. Do not blacklist incompatible plugins on Wayland."
msgstr "ເພື່ອຈຸດປະສົງໃນການດີບັກເທົ່ານັ້ນ. ຢ່າຂຶ້ນບັນຊີດຳປລັກອິນທີ່ບໍ່ເຂົ້າກັນໃນ Wayland."

#: ../src/cairo-dock.c:464
msgid ""
"For debugging purposes. Fail loading the specified plugin module after "
"opening it. Multiple modules can be specified by repeating this option "
"multiple times."
msgstr ""
"ເພື່ອຈຸດປະສົງໃນການດີບັກ. ເຮັດໃຫ້ການໂຫຼດໂມດູນປລັກອິນທີ່ລະບຸໄວ້ລົ້ມເຫຼວຫຼັງຈາກເປີດມັນ. "
"ສາມາດລະບຸຫຼາຍໂມດູນໄດ້ໂດຍການໃຊ້ຕົວເລືອກນີ້ຊ້ຳໆ."

#: ../src/cairo-dock.c:467
msgid ""
"For debugging purposes only. Fail loading all plugin modules (after opening)."
msgstr "ເພື່ອຈຸດປະສົງໃນການດີບັກເທົ່ານັ້ນ. ເຮັດໃຫ້ການໂຫຼດໂມດູນປລັກອິນທັງໝົດລົ້ມເຫຼວ (ຫຼັງຈາກເປີດ)."

#: ../src/cairo-dock.c:470
msgid ""
"For debugging purposes only. Do not check version compatibility after "
"loading a plugin module."
msgstr "ເພື່ອຈຸດປະສົງໃນການດີບັກເທົ່ານັ້ນ. ຢ່າກວດສອບຄວາມເຂົ້າກັນໄດ້ຂອງເວີຊັນຫຼັງຈາກໂຫຼດໂມດູນປລັກອິນ."

#: ../src/cairo-dock.c:473
msgid "For debugging purposes only. Do not use systemd to launch apps."
msgstr "ເພື່ອຈຸດປະສົງໃນການດີບັກເທົ່ານັ້ນ. ຢ່າໃຊ້ systemd ເພື່ອເປີດແອັບ."

#: ../src/cairo-dock.c:476
msgid "For debugging purposes only. Do not use DBus activation to launch apps."
msgstr "ເພື່ອຈຸດປະສົງໃນການດີບັກເທົ່ານັ້ນ. ຢ່າໃຊ້ DBus activation ເພື່ອເປີດແອັບ."

#: ../src/cairo-dock.c:479
msgid ""
"For debugging purposes only. Rely on GIO to launch apps instead of our own "
"implementation (implies --disable-systemd)."
msgstr ""
"ເພື່ອຈຸດປະສົງໃນການດີບັກເທົ່ານັ້ນ. ອີງໃສ່ GIO ເພື່ອເປີດແອັບແທນການຈັດຕັ້ງປະຕິບັດຂອງພວກເຮົາເອງ "
"(ໝາຍຄວາມວ່າ --disable-systemd)."

#: ../src/cairo-dock.c:605
msgid "Use OpenGL in Cairo-Dock"
msgstr "ໃຊ້ OpenGL ໃນ Cairo-Dock"

#: ../src/cairo-dock.c:608 ../src/cairo-dock.c:848
msgid "Yes"
msgstr "ແມ່ນ"

#: ../src/cairo-dock.c:610 ../src/cairo-dock.c:849 ../data/messages:829
msgid "No"
msgstr "ບໍ່"

#: ../src/cairo-dock.c:613
msgid ""
"OpenGL allows you to use the hardware acceleration, reducing the CPU load to "
"the minimum.\n"
"It also allows some pretty visual effects similar to Compiz.\n"
"However, some cards and/or their drivers don't fully support it, which may "
"prevent the dock from running correctly.\n"
"Do you want to activate OpenGL ?\n"
" (To not show this dialog, launch the dock from the Application menu,\n"
"  or with the -o option to force OpenGL and -c to force cairo.)"
msgstr ""
"OpenGL ຊ່ວຍໃຫ້ທ່ານໃຊ້ການເລັ່ງຮາດແວ, ຫຼຸດຜ່ອນການໂຫຼດຂອງ CPU ໃຫ້ເຫຼືອໜ້ອຍທີ່ສຸດ.\n"
" ມັນຍັງຊ່ວຍໃຫ້ມີເອັບເຟັກພາບທີ່ສວຍງາມຄ້າຍຄືກັບ Compiz.\n"
" ຢ່າງໃດກໍຕາມ, ບາງກາດຈໍ ແລະ/ຫຼື ໄດເວີຂອງພວກມັນບໍ່ຮອງຮັບມັນຢ່າງເຕັມທີ່, "
"ເຊິ່ງອາດເຮັດໃຫ້ດັອກເຮັດວຽກບໍ່ຖືກຕ້ອງ.\n"
" ທ່ານຕ້ອງການເປີດໃຊ້ OpenGL ບໍ່?\n"
" (ເພື່ອບໍ່ໃຫ້ສະແດງກ່ອງໂຕ້ຕອບນີ້, ໃຫ້ເປີດດັອກຈາກເມນູແອັບພລິເຄຊັນ,\n"
" ຫຼື ດ້ວຍຕົວເລືອກ -o ເພື່ອບັງຄັບໃຊ້ OpenGL ແລະ -c ເພື່ອບັງຄັບໃຊ້ cairo.)"

