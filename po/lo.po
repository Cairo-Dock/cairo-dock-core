#: ../data/messages:577 ../data/messages:863 ../data/messages:899
msgid "Use a custom font for the text?"
msgstr "ໃຊ້ຟອນກຳນົດເອງສຳລັບຂໍ້ຄວາມບໍ່?"

#: ../data/messages:579 ../data/messages:865 ../data/messages:901
msgid "Text font:"
msgstr "ຟອນຂໍ້ຄວາມ:"

#: ../data/messages:581 ../data/messages:637
msgid "Buttons"
msgstr "ປຸ່ມ"

#: ../data/messages:585
msgid "Size of buttons in the info-bubbles (width x height) :"
msgstr "ຂະໜາດຂອງປຸ່ມໃນຟອງຂໍ້ມູນ (ກວ້າງ x ສູງ) :"

#: ../data/messages:587
msgid "Name of an image to use for the yes/ok button :"
msgstr "ຊື່ຂອງຮູບພາບທີ່ຈະໃຊ້ສຳລັບປຸ່ມ ຕົກລົງ/ແມ່ນ :"

#: ../data/messages:589
msgid "Name of an image to use for the no/cancel button :"
msgstr "ຊື່ຂອງຮູບພາບທີ່ຈະໃຊ້ສຳລັບປຸ່ມ ບໍ່/ຍົກເລີກ :"

#: ../data/messages:591
